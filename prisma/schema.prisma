generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model candidates {
  id          String     @id @default(dbgenerated("uuid_generate_v4()")) @db.Uuid
  election_id String?    @db.Uuid
  number      Int        @default(autoincrement())
  name        String
  bio         String?
  image_url   String?
  created_at  DateTime?  @default(now()) @db.Timestamptz(6)
  site        String?
  create_by   String?
  elections   elections? @relation(fields: [election_id], references: [id], onDelete: Cascade, onUpdate: NoAction)
  votes       votes[]

  @@unique([election_id, number], map: "unique_candidate_number_per_election")
}

model elections {
  id             String       @id @default(dbgenerated("uuid_generate_v4()")) @db.Uuid
  title          String
  description    String?
  start_date     DateTime     @db.Timestamptz(6)
  end_date       DateTime     @db.Timestamptz(6)
  is_active      Boolean?     @default(true)
  created_at     DateTime?    @default(now()) @db.Timestamptz(6)
  reg_start_date DateTime?    @db.Timestamptz(6)
  reg_end_date   DateTime?    @db.Timestamptz(6)
  candidates     candidates[]
  votes          votes[]
}

model users {
  id           String    @id
  name         String?
  email        String?
  line_user_id String?
  created_at   DateTime? @default(now()) @db.Timestamptz(6)
  employee_id  String?
  votes        votes[]
}

model votes {
  id           String      @id @default(dbgenerated("uuid_generate_v4()")) @db.Uuid
  election_id  String?     @db.Uuid
  candidate_id String?     @db.Uuid
  voter_id     String?
  created_at   DateTime?   @default(now()) @db.Timestamptz(6)
  first_name   String?
  last_name    String?
  employee_id  String?
  candidates   candidates? @relation(fields: [candidate_id], references: [id], onDelete: Cascade, onUpdate: NoAction)
  elections    elections?  @relation(fields: [election_id], references: [id], onDelete: Cascade, onUpdate: NoAction)
  users        users?      @relation(fields: [voter_id], references: [id], onDelete: NoAction, onUpdate: NoAction)

  @@unique([election_id, voter_id, candidate_id], map: "unique_vote_per_user_per_candidate")
  @@index([election_id, voter_id])
  @@index([candidate_id])
}

model employees {
  id         BigInt    @id @default(autoincrement())
  emp_id     String    @unique
  status     String?
  title      String?
  name       String?
  surname    String?
  site       String?
  position   String?
  start_date DateTime? @db.Date
  hbd        DateTime? @db.Date
  created_at DateTime? @default(now()) @db.Timestamptz(6)
}
